# ============ Application ============
APP_NAME=RalphGuard
APP_ENV=development
APP_DEBUG=true

# ============ Backend API ============
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-in-production-please-use-long-random-string
CORS_ORIGINS=http://localhost:3000

# ============ Database (PostgreSQL) ============
POSTGRES_USER=ralphguard
POSTGRES_PASSWORD=ralphguard_dev
POSTGRES_DB=ralphguard
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ralphguard:ralphguard_dev@postgres:5432/ralphguard

# ============ Redis ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
QUEUE_STREAM_NAME=ralphguard:jobs

# ============ Frontend ============
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=RalphGuard

# ============ Scientific Worker ============
WORKER_CONCURRENCY=2
MODELS_DIR=/app/models
